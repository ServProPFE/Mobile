pipeline {
	agent any

	parameters {
		booleanParam(name: 'deploy_k8s', defaultValue: true, description: 'Deploy mobile image to Kubernetes after successful checks')
		string(name: 'dockerhub_credential_id', defaultValue: '', description: 'Jenkins username/password credential ID for Docker Hub')
		string(name: 'docker_image_repo', defaultValue: 'docker.io/hechmi10/servpro-mobile', description: 'Docker image repository to push/deploy (example: docker.io/<username>/servpro-mobile)')
		string(name: 'kubeconfig_credential_id', defaultValue: '', description: 'Jenkins secret file credential ID containing kubeconfig for kubectl access')
	}

	triggers {
		githubPush()
		pollSCM('H/5 * * * *')
	}

	environment {
		IMAGE_REPO = "${params.docker_image_repo}"
		IMAGE_TAG = "build-${BUILD_NUMBER}"
		CONTAINER_NAME = 'servpro-mobile-ci'
		K8S_NAMESPACE = 'servpro'
		K8S_DEPLOYMENT = 'mobile'
		K8S_CONTAINER = 'mobile'
	}

	stages {
		stage('Install Dependencies') {
			steps {
				echo 'Installing dependencies...'
				bat 'npm ci'
			}
		}

		stage('Lint') {
			steps {
				echo 'Running lint...'
				bat 'npm run lint'
			}
		}

		stage('Build Docker Image') {
			steps {
				echo 'Building mobile image...'
				bat 'docker build -t %IMAGE_REPO%:latest -t %IMAGE_REPO%:%IMAGE_TAG% .'
			}
		}

		stage('Validate Docker Hub Auth') {
			when {
				expression { params.dockerhub_credential_id?.trim() }
			}
			steps {
				echo 'Validating Docker Hub authentication before push...'
				withCredentials([usernamePassword(credentialsId: params.dockerhub_credential_id.trim(), usernameVariable: 'DOCKERHUB_USERNAME', passwordVariable: 'DOCKERHUB_PASSWORD')]) {
					powershell '''
						$ErrorActionPreference = "Stop"

						$repo = "${env:IMAGE_REPO}".Replace("docker.io/", "")
						$repoParts = $repo.Split('/')
						if ($repoParts.Length -lt 2) {
							throw "Invalid docker_image_repo format: ${env:IMAGE_REPO}. Expected docker.io/<username>/<repo>."
						}

						$repoOwner = $repoParts[0]
						if ($repoOwner -ne $env:DOCKERHUB_USERNAME) {
							throw "Credential username '$($env:DOCKERHUB_USERNAME)' does not match docker_image_repo namespace '$repoOwner'. Use matching Jenkins credential or update docker_image_repo."
						}

						$env:DOCKERHUB_PASSWORD | docker login -u $env:DOCKERHUB_USERNAME --password-stdin
						if ($LASTEXITCODE -ne 0) {
							throw "Docker login failed. Ensure Jenkins username is your Docker Hub username (not email) and password is a PAT token with write permission."
						}

						Write-Host "Docker login succeeded. Target repository: ${env:IMAGE_REPO}"
						docker logout
					'''
				}
			}
		}

		stage('Smoke Test Container') {
			steps {
				bat 'docker rm -f %CONTAINER_NAME% || ver > nul'
				bat 'docker run -d --name %CONTAINER_NAME% -p 8081:8081 %IMAGE_REPO%:%IMAGE_TAG%'
				powershell '''
					$url = "http://localhost:8081"
					$maxAttempts = 15
					$delaySeconds = 5
					$ready = $false

					for ($i = 1; $i -le $maxAttempts; $i++) {
						try {
							$response = Invoke-WebRequest -Uri $url -UseBasicParsing -TimeoutSec 5
							if ($response.StatusCode -ge 200 -and $response.StatusCode -lt 500) {
								$ready = $true
								Write-Host "Mobile web server is reachable on attempt $i with status $($response.StatusCode)."
								break
							}
						} catch {
							Write-Host "Attempt $i/$maxAttempts failed: $($_.Exception.Message)"
						}

						Start-Sleep -Seconds $delaySeconds
					}

					if (-not $ready) {
						docker logs ${env:CONTAINER_NAME}
						throw "Mobile container is not reachable on $url"
					}
				'''
			}
		}

		stage('Push Docker Image') {
			when {
				expression { params.dockerhub_credential_id?.trim() }
			}
			steps {
				echo 'Pushing mobile image to Docker Hub...'
				withCredentials([usernamePassword(credentialsId: params.dockerhub_credential_id.trim(), usernameVariable: 'DOCKERHUB_USERNAME', passwordVariable: 'DOCKERHUB_PASSWORD')]) {
					powershell '''
						$ErrorActionPreference = "Stop"

						$env:DOCKERHUB_PASSWORD | docker login -u $env:DOCKERHUB_USERNAME --password-stdin
						if ($LASTEXITCODE -ne 0) {
							throw "Docker login failed. Check dockerhub_credential_id username/password and repository permissions for ${env:IMAGE_REPO}."
						}

						docker push ${env:IMAGE_REPO}:latest
						if ($LASTEXITCODE -ne 0) {
							throw "Failed to push ${env:IMAGE_REPO}:latest"
						}

						docker push ${env:IMAGE_REPO}:${env:IMAGE_TAG}
						if ($LASTEXITCODE -ne 0) {
							throw "Failed to push ${env:IMAGE_REPO}:${env:IMAGE_TAG}"
						}

						docker logout
					'''
				}
			}
		}

		stage('Deploy To Kubernetes') {
			when {
				allOf {
					expression { params.deploy_k8s }
					expression { params.kubeconfig_credential_id?.trim() }
				}
			}
			steps {
				echo 'Deploying mobile to Kubernetes...'
				withCredentials([file(credentialsId: params.kubeconfig_credential_id.trim(), variable: 'KUBECONFIG_FILE')]) {
					powershell '''
						$ErrorActionPreference = "Stop"
						$env:KUBECONFIG = $env:KUBECONFIG_FILE
						kubectl version --client
						kubectl get namespace ${env:K8S_NAMESPACE} | Out-Null
					'''
					bat 'set KUBECONFIG=%KUBECONFIG_FILE% && kubectl set image deployment/%K8S_DEPLOYMENT% %K8S_CONTAINER%=%IMAGE_REPO%:%IMAGE_TAG% -n %K8S_NAMESPACE%'
					bat 'set KUBECONFIG=%KUBECONFIG_FILE% && kubectl rollout status deployment/%K8S_DEPLOYMENT% -n %K8S_NAMESPACE% --timeout=180s'
				}
			}
		}
	}

	post {
		always {
			bat 'docker rm -f %CONTAINER_NAME% || ver > nul'
		}
	}
}
