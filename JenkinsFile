pipeline {
	agent any

	parameters {
		booleanParam(name: 'deploy_k8s', defaultValue: true, description: 'Deploy mobile image to Kubernetes after successful checks')
		string(name: 'dockerhub_credential_id', defaultValue: '', description: 'Jenkins username/password credential ID for Docker Hub')
	}

	triggers {
		githubPush()
		pollSCM('H/5 * * * *')
	}

	environment {
		IMAGE_REPO = 'docker.io/hechmi10/servpro-mobile'
		IMAGE_TAG = "build-${BUILD_NUMBER}"
		CONTAINER_NAME = 'servpro-mobile-ci'
		K8S_NAMESPACE = 'servpro'
		K8S_DEPLOYMENT = 'mobile'
		K8S_CONTAINER = 'mobile'
	}

	stages {
		stage('Install Dependencies') {
			steps {
				echo 'Installing dependencies...'
				bat 'npm ci'
			}
		}

		stage('Lint') {
			steps {
				echo 'Running lint...'
				bat 'npm run lint'
			}
		}

		stage('Build Docker Image') {
			steps {
				echo 'Building mobile image...'
				bat 'docker build -t %IMAGE_REPO%:latest -t %IMAGE_REPO%:%IMAGE_TAG% .'
			}
		}

		stage('Smoke Test Container') {
			steps {
				bat 'docker rm -f %CONTAINER_NAME% || ver > nul'
				bat 'docker run -d --name %CONTAINER_NAME% -p 8081:8081 %IMAGE_REPO%:%IMAGE_TAG%'
				powershell '''
					$url = "http://localhost:8081"
					$maxAttempts = 15
					$delaySeconds = 5
					$ready = $false

					for ($i = 1; $i -le $maxAttempts; $i++) {
						try {
							$response = Invoke-WebRequest -Uri $url -UseBasicParsing -TimeoutSec 5
							if ($response.StatusCode -ge 200 -and $response.StatusCode -lt 500) {
								$ready = $true
								Write-Host "Mobile web server is reachable on attempt $i with status $($response.StatusCode)."
								break
							}
						} catch {
							Write-Host "Attempt $i/$maxAttempts failed: $($_.Exception.Message)"
						}

						Start-Sleep -Seconds $delaySeconds
					}

					if (-not $ready) {
						docker logs ${env:CONTAINER_NAME}
						throw "Mobile container is not reachable on $url"
					}
				'''
			}
		}

		stage('Push Docker Image') {
			when {
				expression { params.dockerhub_credential_id?.trim() }
			}
			steps {
				echo 'Pushing mobile image to Docker Hub...'
				withCredentials([usernamePassword(credentialsId: params.dockerhub_credential_id.trim(), usernameVariable: 'DOCKERHUB_USERNAME', passwordVariable: 'DOCKERHUB_PASSWORD')]) {
					powershell '''
						$ErrorActionPreference = "Stop"
						$env:DOCKERHUB_PASSWORD | docker login -u $env:DOCKERHUB_USERNAME --password-stdin
						docker push ${env:IMAGE_REPO}:latest
						docker push ${env:IMAGE_REPO}:${env:IMAGE_TAG}
						docker logout
					'''
				}
			}
		}

		stage('Deploy To Kubernetes') {
			when {
				expression { params.deploy_k8s }
			}
			steps {
				echo 'Deploying mobile to Kubernetes...'
				powershell '''
					$kustomizePath = "..\\k8s"
					if (Test-Path $kustomizePath) {
						Write-Host "Applying manifests from $kustomizePath"
						kubectl apply -k $kustomizePath
					} else {
						Write-Host "Kustomize path $kustomizePath not found. Skipping kubectl apply -k and continuing with rollout update."
					}

					if (-not "${params.dockerhub_credential_id}".Trim()) {
						Write-Host "Docker Hub credential not provided. Deploying using locally built image tag: ${env:IMAGE_REPO}:${env:IMAGE_TAG}"
					}
				'''
				bat 'kubectl set image deployment/%K8S_DEPLOYMENT% %K8S_CONTAINER%=%IMAGE_REPO%:%IMAGE_TAG% -n %K8S_NAMESPACE%'
				bat 'kubectl rollout status deployment/%K8S_DEPLOYMENT% -n %K8S_NAMESPACE% --timeout=180s'
			}
		}
	}

	post {
		always {
			bat 'docker rm -f %CONTAINER_NAME% || ver > nul'
		}
	}
}
